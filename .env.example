# PIN dell'organizzatore per sbloccare la modifica (obbligatoria)
ADMIN_PIN=

# Personal Access Token GitHub con permesso di scrittura sui contenuti del repo.
# Necessaria SOLO in produzione (Vercel): senza token, in sviluppo locale i
# salvataggi scrivono direttamente su data/teams.json.
GITHUB_TOKEN=

# Opzionali: default già corretti per questo progetto
# GITHUB_REPO=gioelestrazzarino/fantacalcio-webapp
# GITHUB_BRANCH=main
